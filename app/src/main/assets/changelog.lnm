        - title=Change column count of the Album View
        - title=Toggle black background for media views
        - title=Zoom on videos
        - title=Click on media title to open info dialog
        - title=Avif image loading
        - title=New app icon
        - title=Arabic, Spanish, Russian, Turkish and Ukrainian translations
        - title=Increased custom tab limit
        - title=Immich help and info dialogs
        - title=Retain albums on uninstall
        - title=Open source licenses page
        - title=Tabs for Favourites and Trash views
        - title=In-app wallpaper setter
